---
import { site, icp } from '../config';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href={site.favicon} />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.1/css/all.min.css" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={site.description} />
		<title>{site.title}</title>
	</head>
	<body>
		<div class="page-wrapper">
			<a href="https://www.mcxiaochen.top/" class="home-link" title="返回主页">
				<i class="fa-solid fa-house"></i>
			</a>
			<div class="page-content">
				<slot />
			</div>
			<footer class="site-footer">
				<div class="footer-inner">
					<div class="footer-line">
						<span>
							© <span id="footerYear"></span>
							<a href="https://github.com/mcxiaochenn" target="_blank" rel="noopener">辰渊尘 ChenDusk</a>
						</span>
						<span class="footer-sep">·</span>
						<span class="footer-astro">
							由 <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> 强力驱动
						</span>
						<span class="footer-sep">·</span>
						<span class="footer-uptime">已运行 <span id="uptime"></span></span>
					</div>
					{icp.show && (
						<div class="footer-line footer-icp">
							<a href={icp.link} target="_blank" rel="noopener">{icp.text}</a>
						</div>
					)}
				</div>
			</footer>
		</div>
	</body>
</html>

<script define:vars={{ createdAt: site.createdAt }}>
	document.getElementById('footerYear').textContent = new Date().getFullYear();

	const startTime = new Date(createdAt).getTime();

	function updateUptime() {
		const diff = Date.now() - startTime;
		const s = Math.floor(diff / 1000);
		const d = Math.floor(s / 86400);
		const h = Math.floor((s % 86400) / 3600);
		const m = Math.floor((s % 3600) / 60);
		const sec = s % 60;
		const parts = [];
		if (d > 0) parts.push(d + ' 天');
		parts.push(h + ' 小时');
		parts.push(m + ' 分钟');
		parts.push(sec + ' 秒');
		document.getElementById('uptime').textContent = parts.join(' ');
	}
	updateUptime();
	setInterval(updateUptime, 1000);
</script>

<style is:global>
	*,
	*::before,
	*::after {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
			'Helvetica Neue', Arial, 'Noto Sans', sans-serif;
		background: #0a0a0a;
		color: #fafafa;
		min-height: 100vh;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.page-wrapper {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		position: relative;
	}

	.home-link {
		position: fixed;
		top: 1rem;
		left: 1rem;
		width: 2rem;
		height: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #52525b;
		font-size: 0.875rem;
		border-radius: 0.375rem;
		transition: color 0.15s, background 0.15s;
		text-decoration: none;
		z-index: 50;
	}

	.home-link:hover {
		color: #a1a1aa;
		background: hsla(0, 0%, 100%, 0.05);
	}

	.page-content {
		flex: 1;
	}

	.site-footer {
		padding: 1.5rem;
		border-top: 1px solid hsla(0, 0%, 100%, 0.06);
	}

	.footer-inner {
		max-width: 640px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.375rem;
	}

	.footer-line {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		color: #52525b;
	}

	.footer-line a {
		color: #71717a;
		text-decoration: none;
		transition: color 0.15s;
	}

	.footer-line a:hover {
		color: #a1a1aa;
	}

	.footer-sep {
		color: #27272a;
	}

	.footer-icp {
		margin-top: 0.125rem;
	}

	.footer-icp a {
		color: #3f3f46;
	}

	.footer-icp a:hover {
		color: #52525b;
	}
</style>
